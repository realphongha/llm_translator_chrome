{
  "name": "llm-page-translator",
  "version": "0.1.0",
  "description": "Chrome extension for translating webpages using any OpenAI-compatible API",
  "private": true,
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "clean": "node -e \"const fs=require('fs');const rm=(p)=>{if(fs.existsSync(p)){fs.rmSync(p,{recursive:true})}};rm('dist');\""
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "typescript": "^5.5.4",
    "@types/chrome": "^0.0.270"
  }
}
